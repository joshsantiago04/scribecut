{
    "name": "clip-findr",
    "version": "1.0.0",
    "description": "Search your video library by what was said",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "electron": "electron --no-sandbox .",
        "build": "vite build",
        "dist": "npm run build && electron-builder --publish onTag",
        "dist:win": "npm run build && electron-builder --win --publish onTag",
        "dist:mac": "npm run build && electron-builder --mac --publish onTag",
        "dist:linux": "npm run build && electron-builder --linux --publish onTag"
    },
    "build": {
        "appId": "com.hajolabs.clipfindr",
        "productName": "Clip Findr",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "extraResources": [
            {
                "from": "backend/dist/",
                "to": "backend"
            }
        ],
        "publish": {
            "provider": "github",
            "owner": "joshsantiago04",
            "repo": "clip-findr"
        },
        "win": {
            "target": [
                { "target": "nsis", "arch": ["x64"] }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerFilename": "ClipFindr-Setup.exe"
        },
        "mac": {
            "target": [
                { "target": "dmg", "arch": ["universal"] }
            ],
            "artifactName": "ClipFindr.dmg"
        },
        "linux": {
            "target": [
                { "target": "AppImage", "arch": ["x64"] },
                { "target": "deb", "arch": ["x64"] }
            ]
        },
        "appImage": {
            "artifactName": "ClipFindr.AppImage"
        },
        "deb": {
            "artifactName": "ClipFindr.deb"
        }
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.3.1",
        "electron": "^34.0.0",
        "electron-builder": "^25.0.0",
        "vite": "^6.0.0"
    }
}
