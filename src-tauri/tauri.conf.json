{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "ScribeCut",
    "version": "1.0.1",
    "identifier": "com.hajolabs.scribecut",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:5173",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "ScribeCut",
                "width": 1400,
                "height": 900,
                "minWidth": 900,
                "minHeight": 600,
                "decorations": false,
                "transparent": true,
                "visible": false
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": ["**"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDRjgwMzM1QzQwNTNCRkEKUldUNk93WEVOUVA0TEg3WWVKY0V4clEyWmMvaDRSSzFOWXpwY0xvMnJlczFFeklQbXFHcFhtY2sK",
            "endpoints": [
                "https://downloads.hajolabs.com/scribecut/latest.json"
            ]
        }
    }
}
